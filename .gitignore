# Build artifacts
/target
*.exe
*.dll
*.pdb

# Rust
**/*.rs.bk
*.swp

# Cargo
# Keep Cargo.lock for binary projects (ensures reproducible builds)

# IDE / Editor
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Environment / Secrets
.env
.env.*
!.env.example
!.env.tpl
*.pem
*.key
*.cert

# Local config
.mcp.json
CLAUDE.local.md

# Claude Code / AI tooling working state
# NOTE: CLAUDE.md (the project instructions) stays tracked intentionally.
# Everything else under .claude/ — agent worktrees, local settings,
# session caches — is local-only and MUST NOT be committed.
.claude/
.claude-agent-worktrees/
claude_debug.log
.anthropic/

# Superpowers working docs
docs/superpowers/
.superpowers/

# Dev loop scratch files (probe scripts, test captures, manual test output)
probe-results.txt
/prinstall-probe.ps1
*.probe.log
scratch/
.scratch/

# Temporary files
*.tmp
*.bak
*.log

# Windows installer staging
staging/

# ===== Managed by gitignore-builder — do not edit below this line =====
# Templates: Rust
# Updated: 2026-04-08
# Source: https://github.com/github/gitignore

# ============================================
# Rust.gitignore
# https://github.com/github/gitignore/blob/main/Rust.gitignore
# ============================================
# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
